# Fully open-source LLM stack via Hugging Face.
# Get a free token at https://huggingface.co/settings/tokens (read access is enough)
HF_TOKEN=your_huggingface_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Embedding model (open-source, runs locally, no token needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional — leave blank to skip chat-history logging
DATABASE_URL=postgresql://user:password@localhost:5432/riya_chatbot

VECTORSTORE_DIR=vectorstore_data
FRONTEND_ORIGIN=http://localhost:5173
